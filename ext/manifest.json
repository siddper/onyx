{
  "manifest_version": 3,
  "name": "Onyx - Markdown Notes for Obsidian",
  "version": "1.1",
  "description": "Markdown side panel editor - export notes to Obsidian.",
  "permissions": ["sidePanel", "storage", "contextMenus","tabs"],
  "action": { "default_title": "Open Onyx" },
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "options_ui": { "page": "options.html" },
  "commands": {
    "toggleToolbar": {
      "description": "Toggle toolbar visibility"
    }
  },
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
}
